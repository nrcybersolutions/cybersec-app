[
  {
    "subcategory_id": 1,
    "name": "Phishing",
    "sections": [

      {
        "title": "Overview",
        "type": "text",
        "content": "Phishing is a social engineering attack where attackers impersonate trusted entities to steal credentials, deliver malware, or perform fraud."
      },

      {
        "title": "Investigation Questions",
        "type": "list",
        "content": [
          "Who received the email?",
          "Was the link clicked?",
          "Was any credential entered?",
          "Is the email delivered to multiple users?",
          "Is the sender domain spoofed?",
          "Any mailbox rules created?"
        ]
      },

      {
        "title": "Indicators",
        "type": "list",
        "content": [
          "Lookalike domain (micros0ft.com)",
          "Urgent language",
          "URL mismatch",
          "Suspicious attachment",
          "New domain registration"
        ]
      },

      {
        "title": "Logs",
        "type": "list",
        "content": [
          "Email logs (Defender / Proofpoint)",
          "Message trace",
          "User click events",
          "Entra ID sign-in logs",
          "Mailbox audit logs",
          "Proxy logs"
        ]
      },

      {
        "title": "Tools",
        "type": "tools",
        "content": [
          { "name": "VirusTotal", "link": "https://www.virustotal.com", "type": "all" },
          { "name": "URLScan", "link": "https://urlscan.io", "type": "url" },
          { "name": "PhishTank", "link": "https://phishtank.com", "type": "url" },
          { "name": "MXToolbox", "link": "https://mxtoolbox.com", "type": "domain" }
        ]
      },

      {
        "title": "Containment",
        "type": "list",
        "content": [
          "Block sender/domain",
          "Remove email from all mailboxes",
          "Reset password",
          "Revoke sessions",
          "Enable MFA"
        ]
      },

      {
        "title": "MITRE Mapping",
        "type": "list",
        "content": [
          "T1566 – Phishing",
          "T1566.002 – Spearphishing Link",
          "T1078 – Valid Accounts"
        ]
      },

      {
        "title": "Detection Ideas",
        "type": "list",
        "content": [
          "Same email to multiple users",
          "New domain observed",
          "User clicked suspicious link",
          "Impossible travel login"
        ]
      }

    ]
  },
{
  "subcategory_id": 2,
  "name": "Malware",
  "sections": [

    {
      "title": "Overview",
      "type": "text",
      "content": "Malware refers to malicious software designed to disrupt, damage, or gain unauthorized access to systems. Includes trojans, ransomware, spyware, and loaders."
    },

    {
      "title": "Investigation Questions",
      "type": "list",
      "content": [
        "How was malware delivered (email, download, USB)?",
        "Which process executed the file?",
        "Is there persistence?",
        "Any lateral movement observed?",
        "Is C2 communication present?"
      ]
    },

    {
      "title": "Indicators",
      "type": "list",
      "content": [
        "Unknown process execution",
        "Suspicious parent-child process",
        "File in temp or downloads folder",
        "Encoded PowerShell commands",
        "Connections to suspicious IPs"
      ]
    },

    {
      "title": "Logs",
      "type": "list",
      "content": [
        "EDR alerts (Defender / CrowdStrike)",
        "Process creation logs",
        "Sysmon logs",
        "Network connection logs",
        "File creation events"
      ]
    },

    {
      "title": "Tools",
      "type": "tools",
      "content": [
        { "name": "VirusTotal", "link": "https://www.virustotal.com", "type": "all" },
        { "name": "Any.Run", "link": "https://any.run", "type": "hash" },
        { "name": "Hybrid Analysis", "link": "https://www.hybrid-analysis.com", "type": "hash" },
        { "name": "Joe Sandbox", "link": "https://www.joesandbox.com", "type": "hash" }
      ]
    },

    {
      "title": "Containment",
      "type": "list",
      "content": [
        "Isolate affected endpoint",
        "Kill malicious process",
        "Delete malicious file",
        "Block hash across environment",
        "Reimage system if required"
      ]
    },

    {
      "title": "MITRE Mapping",
      "type": "list",
      "content": [
        "T1059 – Command Execution",
        "T1204 – User Execution",
        "T1105 – Ingress Tool Transfer",
        "T1027 – Obfuscated Files"
      ]
    },

    {
      "title": "Detection Ideas",
      "type": "list",
      "content": [
        "Unusual parent-child process chain",
        "PowerShell encoded commands",
        "Executable running from temp folder",
        "Outbound connections to rare IPs"
      ]
    }

  ]
},
{
  "subcategory_id": 3,
  "name": "Business Email Compromise (BEC)",
  "sections": [

    {
      "title": "Overview",
      "type": "text",
      "content": "BEC is a targeted phishing attack where attackers impersonate executives or vendors to trick users into transferring money or sharing sensitive information."
    },

    {
      "title": "Investigation Questions",
      "type": "list",
      "content": [
        "Is sender spoofed or compromised?",
        "Was any payment requested?",
        "Is there mailbox takeover involved?",
        "Was conversation hijacked?",
        "Any forwarding rules created?"
      ]
    },

    {
      "title": "Indicators",
      "type": "list",
      "content": [
        "CEO/CFO impersonation",
        "Urgent payment request",
        "Change in bank details",
        "Reply-to mismatch",
        "Conversation hijacking"
      ]
    },

    {
      "title": "Logs",
      "type": "list",
      "content": [
        "Email logs",
        "Mailbox audit logs",
        "Sign-in logs",
        "Message trace",
        "Forwarding rule logs"
      ]
    },

    {
      "title": "Tools",
      "type": "tools",
      "content": [
        { "name": "VirusTotal", "link": "https://www.virustotal.com", "type": "all" },
        { "name": "MXToolbox", "link": "https://mxtoolbox.com", "type": "domain" },
        { "name": "Whois Lookup", "link": "https://whois.domaintools.com", "type": "domain" }
      ]
    },

    {
      "title": "Containment",
      "type": "list",
      "content": [
        "Block sender/domain",
        "Notify finance team",
        "Reset compromised account",
        "Remove malicious rules",
        "Monitor for further activity"
      ]
    },

    {
      "title": "MITRE Mapping",
      "type": "list",
      "content": [
        "T1566 – Phishing",
        "T1078 – Valid Accounts"
      ]
    },

    {
      "title": "Detection Ideas",
      "type": "list",
      "content": [
        "Emails with financial keywords",
        "New external sender pretending internal",
        "Unusual reply-to address",
        "High-risk domain similarity"
      ]
    }

  ]
},
{
  "subcategory_id": 4,
  "name": "Credential Compromise",
  "sections": [

    {
      "title": "Overview",
      "type": "text",
      "content": "Credential compromise occurs when an attacker gains access to valid user credentials and uses them to access systems, often leading to unauthorized access, privilege escalation, or data exfiltration."
    },

    {
      "title": "Investigation Questions",
      "type": "list",
      "content": [
        "Was MFA enabled or bypassed?",
        "Is there impossible travel detected?",
        "Any suspicious sign-in location?",
        "Was there mailbox rule creation?",
        "Any privilege escalation observed?"
      ]
    },

    {
      "title": "Indicators",
      "type": "list",
      "content": [
        "Impossible travel login",
        "Login from unusual country",
        "Multiple failed login attempts",
        "New MFA method added",
        "Suspicious mailbox rules"
      ]
    },

    {
      "title": "Logs",
      "type": "list",
      "content": [
        "Entra ID sign-in logs",
        "Audit logs",
        "Conditional access logs",
        "Mailbox audit logs",
        "Defender identity alerts"
      ]
    },

    {
      "title": "Tools",
      "type": "tools",
      "content": [
        { "name": "VirusTotal", "link": "https://www.virustotal.com", "type": "all" },
        { "name": "HaveIBeenPwned", "link": "https://haveibeenpwned.com", "type": "domain" },
        { "name": "AbuseIPDB", "link": "https://www.abuseipdb.com", "type": "ip" },
        { "name": "IPInfo", "link": "https://ipinfo.io", "type": "ip" }
      ]
    },

    {
      "title": "Containment",
      "type": "list",
      "content": [
        "Reset user password",
        "Revoke all sessions",
        "Remove malicious MFA methods",
        "Disable account temporarily",
        "Review and remove mailbox rules"
      ]
    },

    {
      "title": "MITRE Mapping",
      "type": "list",
      "content": [
        "T1078 – Valid Accounts",
        "T1110 – Brute Force",
        "T1556 – Modify Authentication Process"
      ]
    },

    {
      "title": "Detection Ideas",
      "type": "list",
      "content": [
        "Impossible travel alerts",
        "Login from new device/location",
        "Multiple failed login attempts",
        "MFA fatigue detection",
        "Suspicious mailbox rule creation"
      ]
    }

  ]
},
{
  "subcategory_id": 5,
  "name": "Ransomware",
  "sections": [

    {
      "title": "Overview",
      "type": "text",
      "content": "Ransomware is a type of malware that encrypts files or systems and demands payment for decryption. Often involves lateral movement, persistence, and data exfiltration."
    },

    {
      "title": "Investigation Questions",
      "type": "list",
      "content": [
        "How did initial access occur (phishing, RDP, exploit)?",
        "Is lateral movement observed?",
        "Which systems are impacted?",
        "Any data exfiltration before encryption?",
        "What ransomware family is detected?"
      ]
    },

    {
      "title": "Indicators",
      "type": "list",
      "content": [
        "Mass file encryption",
        "Files renamed with extensions (.lock, .encrypted)",
        "Ransom note files",
        "High CPU/disk usage",
        "Suspicious admin tool usage (PsExec, RDP)"
      ]
    },

    {
      "title": "Logs",
      "type": "list",
      "content": [
        "EDR alerts (Defender / CrowdStrike)",
        "Process creation logs",
        "File modification logs",
        "Network lateral movement logs",
        "Authentication logs (RDP, SMB)"
      ]
    },

    {
      "title": "Tools",
      "type": "tools",
      "content": [
        { "name": "VirusTotal", "link": "https://www.virustotal.com", "type": "all" },
        { "name": "NoMoreRansom", "link": "https://www.nomoreransom.org", "type": "hash" },
        { "name": "Any.Run", "link": "https://any.run", "type": "hash" },
        { "name": "Hybrid Analysis", "link": "https://www.hybrid-analysis.com", "type": "hash" }
      ]
    },

    {
      "title": "Containment",
      "type": "list",
      "content": [
        "Isolate infected systems immediately",
        "Disable network access",
        "Stop malicious processes",
        "Block attacker IPs/domains",
        "Preserve forensic evidence"
      ]
    },

    {
      "title": "MITRE Mapping",
      "type": "list",
      "content": [
        "T1486 – Data Encrypted for Impact",
        "T1021 – Remote Services",
        "T1078 – Valid Accounts",
        "T1562 – Defense Evasion"
      ]
    },

    {
      "title": "Detection Ideas",
      "type": "list",
      "content": [
        "Rapid file modification events",
        "Mass file rename activity",
        "Execution of known ransomware tools",
        "Unusual lateral movement",
        "Abnormal admin tool usage"
      ]
    }

  ]
},
{
  "subcategory_id": 6,
  "name": "Unauthorized Access / Suspicious Login",
  "sections": [

    {
      "title": "Overview",
      "type": "text",
      "content": "Unauthorized access refers to suspicious or malicious login attempts where attackers try to gain access using stolen credentials, brute force, or session hijacking."
    },

    {
      "title": "Investigation Questions",
      "type": "list",
      "content": [
        "Is the login location unusual?",
        "Is this a known user device?",
        "Was MFA triggered or bypassed?",
        "Are there multiple failed login attempts?",
        "Any suspicious activity after login?"
      ]
    },

    {
      "title": "Indicators",
      "type": "list",
      "content": [
        "Login from foreign location",
        "Impossible travel",
        "Multiple failed login attempts",
        "Login from unknown device",
        "Login at unusual time"
      ]
    },

    {
      "title": "Logs",
      "type": "list",
      "content": [
        "Entra ID sign-in logs",
        "Authentication logs",
        "Conditional access logs",
        "VPN logs",
        "Firewall logs"
      ]
    },

    {
      "title": "Tools",
      "type": "tools",
      "content": [
        { "name": "AbuseIPDB", "link": "https://www.abuseipdb.com", "type": "ip" },
        { "name": "IPInfo", "link": "https://ipinfo.io", "type": "ip" },
        { "name": "GreyNoise", "link": "https://www.greynoise.io", "type": "ip" },
        { "name": "VirusTotal", "link": "https://www.virustotal.com", "type": "all" }
      ]
    },

    {
      "title": "Containment",
      "type": "list",
      "content": [
        "Reset user password",
        "Revoke active sessions",
        "Force MFA re-registration",
        "Disable account temporarily",
        "Block suspicious IP"
      ]
    },

    {
      "title": "MITRE Mapping",
      "type": "list",
      "content": [
        "T1078 – Valid Accounts",
        "T1110 – Brute Force",
        "T1021 – Remote Services"
      ]
    },

    {
      "title": "Detection Ideas",
      "type": "list",
      "content": [
        "Impossible travel detection",
        "Login from risky IP",
        "Multiple failed login attempts",
        "Login from new country/device",
        "MFA fatigue patterns"
      ]
    }

  ]
},
{
  "subcategory_id": 7,
  "name": "IOC Investigation (IP / URL / Hash)",
  "sections": [

    {
      "title": "Overview",
      "type": "text",
      "content": "IOC investigation involves analyzing indicators such as IP addresses, domains, URLs, and file hashes to determine if they are malicious and related to threat activity."
    },

    {
      "title": "Investigation Questions",
      "type": "list",
      "content": [
        "Is the IOC malicious or benign?",
        "Is it part of known threat campaigns?",
        "What is the reputation score?",
        "Is there any communication with this IOC?",
        "What infrastructure is associated?"
      ]
    },

    {
      "title": "Indicators",
      "type": "list",
      "content": [
        "Known malicious IP/domain",
        "Newly registered domain",
        "Suspicious URL pattern",
        "Unknown file hash",
        "Connection to rare external IP"
      ]
    },

    {
      "title": "Logs",
      "type": "list",
      "content": [
        "Firewall logs",
        "Proxy logs",
        "DNS logs",
        "EDR network connections",
        "SIEM correlation logs"
      ]
    },

    {
      "title": "Tools",
      "type": "tools",
      "content": [
        { "name": "VirusTotal", "link": "https://www.virustotal.com", "type": "all" },
        { "name": "URLScan", "link": "https://urlscan.io", "type": "url" },
        { "name": "AbuseIPDB", "link": "https://www.abuseipdb.com", "type": "ip" },
        { "name": "IPInfo", "link": "https://ipinfo.io", "type": "ip" },
        { "name": "GreyNoise", "link": "https://www.greynoise.io", "type": "ip" },
        { "name": "MXToolbox", "link": "https://mxtoolbox.com", "type": "domain" },
        { "name": "Whois Lookup", "link": "https://whois.domaintools.com", "type": "domain" }
      ]
    },

    {
      "title": "Containment",
      "type": "list",
      "content": [
        "Block IP/domain at firewall",
        "Block URL in proxy",
        "Block hash in EDR",
        "Add IOC to watchlist",
        "Alert for future activity"
      ]
    },

    {
      "title": "MITRE Mapping",
      "type": "list",
      "content": [
        "T1071 – Application Layer Protocol",
        "T1046 – Network Service Scanning",
        "T1595 – Active Scanning"
      ]
    },

    {
      "title": "Detection Ideas",
      "type": "list",
      "content": [
        "Connections to known malicious IPs",
        "DNS queries to rare domains",
        "Outbound traffic to suspicious regions",
        "File hash seen across endpoints",
        "Beaconing pattern detection"
      ]
    }

  ]
}
]
