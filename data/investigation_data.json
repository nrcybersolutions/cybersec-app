[
  {
    "subcategory_id": 1,
    "name": "Phishing",
    "sections": [

      {
        "title": "Overview",
        "type": "text",
        "content": "Phishing is a social engineering attack where attackers impersonate trusted entities to steal credentials, deliver malware, or perform fraud."
      },

      {
        "title": "Investigation Questions",
        "type": "list",
        "content": [
          "Who received the email?",
          "Was the link clicked?",
          "Was any credential entered?",
          "Is the email delivered to multiple users?",
          "Is the sender domain spoofed?",
          "Any mailbox rules created?"
        ]
      },

      {
        "title": "Indicators",
        "type": "list",
        "content": [
          "Lookalike domain (micros0ft.com)",
          "Urgent language",
          "URL mismatch",
          "Suspicious attachment",
          "New domain registration"
        ]
      },

      {
        "title": "Logs",
        "type": "list",
        "content": [
          "Email logs (Defender / Proofpoint)",
          "Message trace",
          "User click events",
          "Entra ID sign-in logs",
          "Mailbox audit logs",
          "Proxy logs"
        ]
      },

      {
        "title": "Tools",
        "type": "tools",
        "content": [
          { "name": "VirusTotal", "link": "https://www.virustotal.com", "type": "all" },
          { "name": "URLScan", "link": "https://urlscan.io", "type": "url" },
          { "name": "PhishTank", "link": "https://phishtank.com", "type": "url" },
          { "name": "MXToolbox", "link": "https://mxtoolbox.com", "type": "domain" }
        ]
      },

      {
        "title": "Containment",
        "type": "list",
        "content": [
          "Block sender/domain",
          "Remove email from all mailboxes",
          "Reset password",
          "Revoke sessions",
          "Enable MFA"
        ]
      },

      {
        "title": "MITRE Mapping",
        "type": "list",
        "content": [
          "T1566 – Phishing",
          "T1566.002 – Spearphishing Link",
          "T1078 – Valid Accounts"
        ]
      },

      {
        "title": "Detection Ideas",
        "type": "list",
        "content": [
          "Same email to multiple users",
          "New domain observed",
          "User clicked suspicious link",
          "Impossible travel login"
        ]
      }

    ]
  },
{
  "subcategory_id": 2,
  "name": "Malware",
  "sections": [

    {
      "title": "Overview",
      "type": "text",
      "content": "Malware refers to malicious software designed to disrupt, damage, or gain unauthorized access to systems. Includes trojans, ransomware, spyware, and loaders."
    },

    {
      "title": "Investigation Questions",
      "type": "list",
      "content": [
        "How was malware delivered (email, download, USB)?",
        "Which process executed the file?",
        "Is there persistence?",
        "Any lateral movement observed?",
        "Is C2 communication present?"
      ]
    },

    {
      "title": "Indicators",
      "type": "list",
      "content": [
        "Unknown process execution",
        "Suspicious parent-child process",
        "File in temp or downloads folder",
        "Encoded PowerShell commands",
        "Connections to suspicious IPs"
      ]
    },

    {
      "title": "Logs",
      "type": "list",
      "content": [
        "EDR alerts (Defender / CrowdStrike)",
        "Process creation logs",
        "Sysmon logs",
        "Network connection logs",
        "File creation events"
      ]
    },

    {
      "title": "Tools",
      "type": "tools",
      "content": [
        { "name": "VirusTotal", "link": "https://www.virustotal.com", "type": "all" },
        { "name": "Any.Run", "link": "https://any.run", "type": "hash" },
        { "name": "Hybrid Analysis", "link": "https://www.hybrid-analysis.com", "type": "hash" },
        { "name": "Joe Sandbox", "link": "https://www.joesandbox.com", "type": "hash" }
      ]
    },

    {
      "title": "Containment",
      "type": "list",
      "content": [
        "Isolate affected endpoint",
        "Kill malicious process",
        "Delete malicious file",
        "Block hash across environment",
        "Reimage system if required"
      ]
    },

    {
      "title": "MITRE Mapping",
      "type": "list",
      "content": [
        "T1059 – Command Execution",
        "T1204 – User Execution",
        "T1105 – Ingress Tool Transfer",
        "T1027 – Obfuscated Files"
      ]
    },

    {
      "title": "Detection Ideas",
      "type": "list",
      "content": [
        "Unusual parent-child process chain",
        "PowerShell encoded commands",
        "Executable running from temp folder",
        "Outbound connections to rare IPs"
      ]
    }

  ]
}
]
